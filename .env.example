INTENTIA_ENV=prod
INTENTIA_TIMEZONE=Europe/Uzhgorod
INTENTIA_PAIR_ID=yaroslav_dasha
INTENTIA_DATABASE_URL=postgresql+asyncpg://intentia:intentia@postgres:5432/intentia
INTENTIA_SQLITE_FALLBACK=sqlite+aiosqlite:///./intentia_amoris.db
INTENTIA_REQUIRE_API_AUTH=true
INTENTIA_ALLOW_INSECURE_DEV=false
INTENTIA_API_KEYS=replace-with-generated-32-byte-token
INTENTIA_SECRET_KEY=replace-with-generated-32-byte-secret
INTENTIA_AUDIT_LOG_PATH=./data/audit/audit.jsonl
INTENTIA_RATE_LIMIT_PER_MINUTE=120
INTENTIA_MAX_CONTENT_CHARS=8000
INTENTIA_MAX_MEDIA_BYTES=15728640
INTENTIA_ALLOWED_MEDIA_EXTENSIONS=.jpg,.jpeg,.png,.webp,.mp3,.wav,.ogg,.m4a,.mp4,.mov
TELEGRAM_BOT_TOKEN=
INTENTIA_ALLOWED_USER_IDS=
INTENTIA_EMBEDDING_PROVIDER=local
INTENTIA_EMBEDDING_DIM=384
OPENAI_API_KEY=
INTENTIA_MEDIA_ROOT=./data/media
INTENTIA_REQUIRE_PARTNER_CONSENT=true
INTENTIA_DEFAULT_PRIVACY_SCOPE=pair_private
