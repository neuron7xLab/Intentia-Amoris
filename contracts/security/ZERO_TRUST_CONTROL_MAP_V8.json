        "tests/test_security_v7.py"
      ]
    },
    {
      "id": "ZT-02",
      "control": "runtime secret validation",
      "implementation": "Settings.assert_runtime_safe",
      "tests": [
        "tests/test_security_v7.py"
      ]
    },
    {
      "id": "ZT-03",
      "control": "rate limiting",
      "implementation": "intentia_amoris.security.rate_limit",
